<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ComicSort.UI.ViewModels.Dialogs"
        x:Class="ComicSort.UI.Views.Dialogs.TargetedScanFolderSelectionDialog"
        x:DataType="vm:TargetedScanFolderSelectionDialogViewModel"
        Width="680"
        Height="500"
        MinWidth="560"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Title="Targeted Scan"
        Background="{DynamicResource Theme.BackgroundBrush}"
        Foreground="{DynamicResource Theme.PrimaryTextBrush}"
        mc:Ignorable="d"
        d:DesignWidth="680"
        d:DesignHeight="500">

    <Border Margin="14"
            Padding="14"
            BorderBrush="{DynamicResource Theme.BorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Background="{DynamicResource Theme.SurfaceBrush}">
        <Grid RowDefinitions="Auto,Auto,*,Auto"
              RowSpacing="10">
            <TextBlock Text="Choose library folders to scan"
                       FontSize="16"
                       FontWeight="SemiBold" />

            <Grid Grid.Row="1"
                  ColumnDefinitions="Auto,Auto,*"
                  ColumnSpacing="8">
                <Button Content="Select All"
                        Command="{Binding SelectAllCommand}"
                        IsVisible="{Binding HasFolders}"
                        MinWidth="100" />
                <Button Grid.Column="1"
                        Content="Clear"
                        Command="{Binding ClearSelectionCommand}"
                        IsVisible="{Binding HasFolders}"
                        MinWidth="100" />
                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           Text="{Binding StatusText}"
                           Foreground="{DynamicResource Theme.SecondaryTextBrush}" />
            </Grid>

            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource Theme.BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8">
                <Grid>
                    <ScrollViewer IsVisible="{Binding HasFolders}">
                        <ItemsControl ItemsSource="{Binding FolderOptions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TargetedScanFolderOptionViewModel">
                                    <Border Padding="4">
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                            <TextBlock Text="{Binding FolderPath}" TextWrapping="Wrap" />
                                        </CheckBox>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock IsVisible="{Binding HasNoFolders}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Text="No configured folders found."
                               Foreground="{DynamicResource Theme.SecondaryTextBrush}" />
                </Grid>
            </Border>

            <Grid Grid.Row="3"
                  ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="8">
                <TextBlock Text="Only folders already configured in Settings can be scanned here."
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Theme.SecondaryTextBrush}" />
                <Button Grid.Column="1"
                        Content="Cancel"
                        Command="{Binding CancelCommand}"
                        MinWidth="100" />
                <Button Grid.Column="2"
                        Content="Start Scan"
                        Command="{Binding StartTargetedScanCommand}"
                        IsEnabled="{Binding CanStartScan}"
                        MinWidth="110"
                        Background="{DynamicResource Theme.AccentBrush}"
                        Foreground="{DynamicResource Theme.OnAccentBrush}" />
            </Grid>
        </Grid>
    </Border>
</Window>

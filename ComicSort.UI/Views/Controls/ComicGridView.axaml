<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ComicSort.UI.ViewModels.Controls"
             xmlns:model="using:ComicSort.UI.Models"
             x:Class="ComicSort.UI.Views.Controls.ComicGridView"
             x:Name="Root"
             x:DataType="vm:ComicGridViewModel">

    <Border Background="{DynamicResource Theme.SurfaceBrush}"
            BorderBrush="{DynamicResource Theme.BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="8">
        <Grid ColumnDefinitions="*,Auto"
              ColumnSpacing="8">
            <Grid Grid.Column="0">
            <ListBox x:Name="FlatListBox"
                     ItemsSource="{Binding Items}"
                     IsVisible="{Binding IsFlatView}"
                     SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                     SelectionMode="Multiple"
                     SelectionChanged="FlatListBox_OnSelectionChanged"
                     BorderThickness="0"
                     Background="Transparent">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Margin" Value="2" />
                        <Setter Property="Padding" Value="2" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="1" />
                    </Style>
                    <Style Selector="ListBoxItem:pointerover">
                        <Setter Property="Background" Value="{DynamicResource Theme.SelectionBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource Theme.BorderBrush}" />
                    </Style>
                    <Style Selector="ListBoxItem:selected">
                        <Setter Property="Background" Value="{DynamicResource Theme.SelectionBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource Theme.AccentBrush}" />
                    </Style>
                </ListBox.Styles>

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"
                                   ItemWidth="100"
                                   ItemHeight="190" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="model:ComicTileModel">
                        <StackPanel Width="92"
                                    Margin="4"
                                    Spacing="4">
                            <StackPanel.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Info"
                                              Command="{Binding #Root.DataContext.ShowInfoCommand}"
                                              CommandParameter="{Binding}" />
                                    <Separator/>
                                    <MenuItem Header="Convert to CBZ"
                                              Command="{Binding #Root.DataContext.ConvertToCbzCommand}"
                                              CommandParameter="{Binding}" />
                                    <Separator/>
                                    <MenuItem Header="Delete"
                                              Command="{Binding #Root.DataContext.DeleteFromLibraryCommand}"
                                              CommandParameter="{Binding}" />
                                </ContextMenu>
                            </StackPanel.ContextMenu>
                            <Border Height="132"
                                    CornerRadius="4"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource Theme.BorderBrush}"
                                    Background="{DynamicResource Theme.PanelBrush}">
                                <Grid>
                                    <Image Stretch="Fill"
                                           Source="{Binding ThumbnailImage}" />
                                    <Border HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Margin="4"
                                            Background="{DynamicResource Theme.AccentBrush}"
                                            CornerRadius="3"
                                            Padding="4,1">
                                        <TextBlock Text="{Binding FileTypeTag}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource Theme.OnAccentBrush}" />
                                    </Border>
                                </Grid>
                            </Border>
                            <TextBlock Text="{Binding DisplayTitle}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Foreground="{DynamicResource Theme.PrimaryTextBrush}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <ScrollViewer IsVisible="{Binding IsGroupedView}"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="model:ComicGroupModel">
                            <Expander IsExpanded="{Binding IsExpanded}"
                                      Margin="0,0,0,8"
                                      Background="Transparent"
                                      HorizontalAlignment="Stretch">
                                <Expander.Header>
                                    <TextBlock Text="{Binding Header}"
                                               FontSize="16"
                                               Foreground="{DynamicResource Theme.AccentBrush}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                </Expander.Header>
                                <ListBox ItemsSource="{Binding Items}"
                                         SelectionMode="Multiple"
                                         SelectionChanged="GroupedListBox_OnSelectionChanged"
                                         BorderThickness="0"
                                         Background="Transparent">
                                    <ListBox.Styles>
                                        <Style Selector="ListBoxItem">
                                            <Setter Property="Margin" Value="2" />
                                            <Setter Property="Padding" Value="2" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderBrush" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="1" />
                                        </Style>
                                        <Style Selector="ListBoxItem:pointerover">
                                            <Setter Property="Background" Value="{DynamicResource Theme.SelectionBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource Theme.BorderBrush}" />
                                        </Style>
                                        <Style Selector="ListBoxItem:selected">
                                            <Setter Property="Background" Value="{DynamicResource Theme.SelectionBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource Theme.AccentBrush}" />
                                        </Style>
                                    </ListBox.Styles>

                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"
                                                       ItemWidth="100"
                                                       ItemHeight="190" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>

                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="model:ComicTileModel">
                                            <StackPanel Width="92"
                                                        Margin="4"
                                                        Spacing="4">
                                                <StackPanel.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Info"
                                                                  Command="{Binding #Root.DataContext.ShowInfoCommand}"
                                                                  CommandParameter="{Binding}" />
                                                        <Separator/>
                                                        <MenuItem Header="Convert to CBZ"
                                                                  Command="{Binding #Root.DataContext.ConvertToCbzCommand}"
                                                                  CommandParameter="{Binding}" />
                                                        <Separator/>
                                                        <MenuItem Header="Delete"
                                                                  Command="{Binding #Root.DataContext.DeleteFromLibraryCommand}"
                                                                  CommandParameter="{Binding}" />
                                                    </ContextMenu>
                                                </StackPanel.ContextMenu>
                                                <Border Height="132"
                                                        CornerRadius="4"
                                                        BorderThickness="1"
                                                        BorderBrush="{DynamicResource Theme.BorderBrush}"
                                                        Background="{DynamicResource Theme.PanelBrush}">
                                                    <Grid>
                                                        <Image Stretch="Fill"
                                                               Source="{Binding ThumbnailImage}" />
                                                        <Border HorizontalAlignment="Left"
                                                                VerticalAlignment="Top"
                                                                Margin="4"
                                                                Background="{DynamicResource Theme.AccentBrush}"
                                                                CornerRadius="3"
                                                                Padding="4,1">
                                                            <TextBlock Text="{Binding FileTypeTag}"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource Theme.OnAccentBrush}" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <TextBlock Text="{Binding DisplayTitle}"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"
                                                           TextAlignment="Center"
                                                           Foreground="{DynamicResource Theme.PrimaryTextBrush}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            </Grid>

            <Border Grid.Column="1"
                    Width="360"
                    IsVisible="{Binding IsInfoPanelOpen}"
                    Background="{DynamicResource Theme.PanelBrush}"
                    BorderBrush="{DynamicResource Theme.BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="6">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding InfoPanel.DisplayTitle}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource Theme.PrimaryTextBrush}" />
                            <TextBlock Text="{Binding InfoPanel.MetadataSource}"
                                       FontSize="11"
                                       Foreground="{DynamicResource Theme.SecondaryTextBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="X"
                                Width="24"
                                Height="24"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Command="{Binding CloseInfoPanelCommand}" />
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="10">
                            <Border Height="190"
                                    CornerRadius="4"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource Theme.BorderBrush}"
                                    Background="{DynamicResource Theme.SurfaceBrush}">
                                <Image Stretch="Uniform"
                                       Source="{Binding InfoPanel.CoverImage}" />
                            </Border>

                            <TextBlock Text="Loading metadata..."
                                       IsVisible="{Binding IsInfoLoading}"
                                       FontStyle="Italic"
                                       Foreground="{DynamicResource Theme.SecondaryTextBrush}" />

                            <TextBlock Text="{Binding InfoError}"
                                       IsVisible="{Binding HasInfoError}"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource Theme.AccentBrush}" />

                            <Grid IsVisible="{Binding !IsInfoLoading}"
                                  ColumnDefinitions="Auto,*"
                                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                  ColumnSpacing="8"
                                  RowSpacing="4">
                                <TextBlock Text="Series:" Grid.Row="0" />
                                <TextBox Text="{Binding InfoPanel.Series, Mode=TwoWay}" Grid.Row="0" Grid.Column="1" />
                                <TextBlock Text="Title:" Grid.Row="1" />
                                <TextBox Text="{Binding InfoPanel.Title, Mode=TwoWay}" Grid.Row="1" Grid.Column="1" />
                                <TextBlock Text="Issue:" Grid.Row="2" />
                                <TextBox Text="{Binding InfoPanel.IssueNumber, Mode=TwoWay}" Grid.Row="2" Grid.Column="1" />
                                <TextBlock Text="Volume:" Grid.Row="3" />
                                <TextBox Text="{Binding InfoPanel.Volume, Mode=TwoWay}" Grid.Row="3" Grid.Column="1" />
                                <TextBlock Text="Year:" Grid.Row="4" />
                                <TextBox Text="{Binding InfoPanel.Year, Mode=TwoWay}" Grid.Row="4" Grid.Column="1" />
                                <TextBlock Text="Publisher:" Grid.Row="5" />
                                <TextBox Text="{Binding InfoPanel.Publisher, Mode=TwoWay}" Grid.Row="5" Grid.Column="1" />
                                <TextBlock Text="Writer:" Grid.Row="6" />
                                <TextBox Text="{Binding InfoPanel.Writer, Mode=TwoWay}" Grid.Row="6" Grid.Column="1" />
                                <TextBlock Text="Penciller:" Grid.Row="7" />
                                <TextBox Text="{Binding InfoPanel.Penciller, Mode=TwoWay}" Grid.Row="7" Grid.Column="1" />
                                <TextBlock Text="Inker:" Grid.Row="8" />
                                <TextBox Text="{Binding InfoPanel.Inker, Mode=TwoWay}" Grid.Row="8" Grid.Column="1" />
                                <TextBlock Text="Colorist:" Grid.Row="9" />
                                <TextBox Text="{Binding InfoPanel.Colorist, Mode=TwoWay}" Grid.Row="9" Grid.Column="1" />
                                <TextBlock Text="Pages:" Grid.Row="10" />
                                <TextBox Text="{Binding InfoPanel.PageCount, Mode=TwoWay}" Grid.Row="10" Grid.Column="1" />
                                <TextBlock Text="Type:" Grid.Row="11" />
                                <TextBox Text="{Binding InfoPanel.FileType, Mode=TwoWay}" Grid.Row="11" Grid.Column="1" />
                                <TextBlock Text="Added:" Grid.Row="12" />
                                <TextBox Text="{Binding InfoPanel.LastScanned, Mode=TwoWay}" Grid.Row="12" Grid.Column="1" />
                                <TextBlock Text="Where:" Grid.Row="13" VerticalAlignment="Top" />
                                <TextBox Text="{Binding InfoPanel.FilePath, Mode=TwoWay}" Grid.Row="13" Grid.Column="1" TextWrapping="Wrap" />
                            </Grid>

                            <TextBlock Text="Summary"
                                       FontWeight="SemiBold"
                                       IsVisible="{Binding !IsInfoLoading}" />
                            <Border IsVisible="{Binding !IsInfoLoading}"
                                    BorderBrush="{DynamicResource Theme.BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Background="{DynamicResource Theme.SurfaceBrush}"
                                    Padding="8">
                                <TextBox Text="{Binding InfoPanel.Summary, Mode=TwoWay}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         MinHeight="84"
                                         VerticalContentAlignment="Top"
                                         Foreground="{DynamicResource Theme.PrimaryTextBrush}" />
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
